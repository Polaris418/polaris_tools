# =========================
# 数据库
# =========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=polaris
DB_USERNAME=root
DB_PASSWORD=123456

# =========================
# JWT（必填，建议至少 32 个字符）
# =========================
JWT_SECRET=polaris-dev-secret-key-change-this-in-production-minimum-32-chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
JWT_REMEMBER_ME_EXPIRATION=2592000000

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================
# 邮件服务（resend / aws-ses）
# =========================
EMAIL_PROVIDER=resend

# Resend（使用 resend 时必填）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@polaristools.online
RESEND_FROM_NAME=Polaris Tools
RESEND_ENABLED=true

# AWS SES（使用 aws-ses 时必填）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=ap-northeast-1
AWS_SES_FROM_EMAIL=noreply@polaristools.online
AWS_SES_ENABLED=false

# =========================
# 其他
# =========================
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1.0
FLYWAY_VALIDATE_ON_MIGRATE=true
SPRINGDOC_ENABLED=true
